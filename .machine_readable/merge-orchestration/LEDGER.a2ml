# LEDGER.a2ml — Merge Orchestration workstream: canonical, compaction-proof state.
# This is the durable record for the cross-repo "merge orchestration" feature.
# It is NOT the repo's canonical 6a2/STATE.a2ml (held pending realignment) — it is
# the workstream ledger. READ THIS FIRST to re-orient after any context reset.
@profile(id=a2ml/state)

[metadata]
workstream = "merge-orchestration"
version = "0.2.0"
last-updated = "2026-06-05"
owner = "paraordinate (Jonathan D.A. Jewell)"
branch = "claude/peaceful-pascal-IRlgq"   # same branch name across all in-scope repos
status = "active — Wave 0 (contracts)"

[thesis]
# A merge decision is a TUPLE over three near-orthogonal axes, never one score:
#   route  = who is authoritative (proof->echidnabot, bump->patch-bridge, structure->rhodibot,
#            security->panicbot, CI->robot-repo-automaton; license/SPDX->none, hard flag)
#   method = history shape (squash|rebase|merge_commit), set by repo policy + commit hygiene
#   safety = arm_auto|review|flag, set by council confidence + vetoes, clamped by pool
# Consensus = "Kin Council": competence-weighted aggregation + MONOTONE VETO (any veto -> flag).
#   NOT Byzantine (bots are cooperative specialists; integrity comes from signed attestations).
# Reflexivity guard: change_level=meta (edits CI / hypatia rules / bot_directives / standards)
#   -> always flag. The actuator may PROPOSE oracle changes, never self-approve them.

[decisions]
# Owner rulings banked 2026-06-05:
nix = "REMOVED estate-wide — guix.scm / guix channels only. flake.nix to be deleted; nix bumps CLOSED not merged."
mr-layout = "6a2/ subdir is canonical; standards CLAUDE.md to be reconciled to it."
leases = "central, Kin.Gate-backed (NOT per-repo files) — fixes the bootstrap race; this IS the kin enhancement."
codecite-prooftrace = "their own CITE + PROVE contractile pair."
operating-mode = "full GitHub ops (token re-authed 2026-06-05)."
ledger = "this file."

[build-order]
# Owner-chosen sequence:
step-1 = "CVE/bump gate (unblocks the held dependabot backlog) — IN PROGRESS"
step-2 = "Attestation schema (Ed25519, reuse panic-attack intent->evidence->seal)"
step-3 = "Pool<->TRUST + Kin-backed lease/coordination spec (lands in standards)"
later  = "verisimdb entity model + PolicyDrift; CodeCite/ProofTrace"

[wave-0-artifacts]
a1 = "decision contract — LANDED on hypatia/main (PR #442, merged 2026-06-05). doc + schema + +/- fixtures, ajv-validated."
a2 = "CVE/bump gate — LANDED on hypatia/main (PR #443, merged 2026-06-05). bump-decision.schema (extends a1) + bump fixtures, ajv-validated."
a3 = "attestation — LANDED on hypatia/main (PR #444, merged 2026-06-05). ed25519 sign/verify/tamper round-trip PASSED + ajv A1/A2/A3."
a4 = "CVE/bump gate in CI — LANDED on hypatia/main (PR #459). bridge-gate.yml template + bridge-verdict.sh (B1 core) + mock BridgeReports, tested. WIRED into 5 cargo repos (reposystem#114, hypatia#460, verisimdb#133, panic-attack#127, echidna#246 — all merged 2026-06-13); 8 reposystem bumps rebased through it; 3 nix bumps closed (B3)."
a5 = "pool/lease spec — this commit. 04-pool-lease-spec.adoc + schemas/{pool-policy,lease}.schema.json + fixtures; pools P0-P3+mass_squash <-> TRUST levels + clamp law; central Kin.Gate-backed lease (the runtime tier). ajv-validated: PL1/PL2/LE1/LE2 all reject correctly. standards adoption (TRUST trust-deny meta extension + INTENT lease-schema fill) is an owner-applied follow-on per standards' own ask-before-touching."

[gated-pr-ledger]
# Applying the gate by hand to all open PRs across 11 in-scope repos (2026-06-05).
# ARMED: hypatia#442 (now merged). Everything else HELD (reason / unblock):
held-license      = "standards#376,#373 -> veto:license (owner-only, never auto)"
held-meta-ci      = "vcl-ut#51; echidna#237 (actions bump edits workflows) -> meta:edits-CI-oracle"
held-proof        = "vcl-ut#52; echidna#234 -> needs proof attestation (echidnabot offline) + rebase/coord"
held-bumps        = "2026-06-12 re-triage: echidna#243 (actions->meta/review); reposystem #106 redis + #95 toml (major->review); 8 cargo minor/patch (#96-#107) -> needs CVE gate = bridge-gate.yml run in CI."
held-nix          = "CLOSED 2026-06-12: reposystem#113/#112/#109 (B3 + @dependabot ignore). Root fix still open: remove flake.nix (separate Nix campaign)."
held-core-code    = "echidna#232 -> core-tier code change -> conservative/review (docs/chore would arm)"
held-realignment  = "verisimdb#107 -> held:6a2-realignment + owner-review-requested"

[coordination]
do-not-touch  = "branch claude/peaceful-pascal-IRlgq; gitbot-fleet dispatch-runner.sh license gate; my contractile/bot_directive/merge-orchestration territory"
hold          = "6a2/STATE,META + anchors/ANCHOR in {hypatia,gitbot-fleet,.git-private-farm,verisimdb,standards} pending realignment"
other-agents  = "claude/nice-ptolemy-lNB8E (standards), claude/loving-cannon-AtUSm (echidna), claude/abi-tier2-and-l10-trans-cycle (vcl-ut), claude/affinescript-migration-wip (reposystem)"

[next]
step = "Wave-0 design COMPLETE (a1-a5). RUNTIME COMPLETE + OUTPUT GLUE: 4 increments (Strategist + Kin.Council + Dispatcher [hypatia]; actuator [.git-private-farm #77]) + Dispatcher.decide_all/write_manifest emitting the merge-decision JSONL the dispatch-runner/actuator consume (Jason encoder injectable so it tests dep-free; prod uses Jason). 22 ExUnit (hypatia) + 5 bash (farm), 0 failures, local elixir 1.14. REMAINING: the INPUT/sensory layer (fetch open PRs + build contexts from bot attestations + bot_directive pools, feed into Dispatcher) is the big remaining wiring; plus real central Kin.Gate lease storage; GoT/MoE competence weights into KinCouncil (currently uniform); owner follow-ons (required-checks per repo; a5 standards adoption; P3 handshake + mass_squash; .git-private-farm Actions billing is dead -- fix before the actuator runs scheduled)."
