# the workstream ledger. READ THIS FIRST to re-orient after any context reset.
@profile(id=a2ml/state)

[metadata]
workstream = "merge-orchestration"
version = "0.10.0"
last-updated = "2026-06-14"
owner = "paraordinate (Jonathan D.A. Jewell)"
branch = "claude/peaceful-pascal-IRlgq"   # same branch name across all in-scope repos
status = "active — Wave 0 (contracts)"

[thesis]
# A merge decision is a TUPLE over three near-orthogonal axes, never one score:
#   route  = who is authoritative (proof->echidnabot, bump->patch-bridge, structure->rhodibot,
#            security->panicbot, CI->robot-repo-automaton; license/SPDX->none, hard flag)
#   method = history shape (squash|rebase|merge_commit), set by repo policy + commit hygiene
#   safety = arm_auto|review|flag, set by council confidence + vetoes, clamped by pool
# Consensus = "Kin Council": competence-weighted aggregation + MONOTONE VETO (any veto -> flag).
#   NOT Byzantine (bots are cooperative specialists; integrity comes from signed attestations).
# Reflexivity guard: change_level=meta (edits CI / hypatia rules / bot_directives / standards)
#   -> always flag. The actuator may PROPOSE oracle changes, never self-approve them.

[decisions]
# Owner rulings banked 2026-06-05:
nix = "REMOVED estate-wide — guix.scm / guix channels only. flake.nix to be deleted; nix bumps CLOSED not merged."
mr-layout = "6a2/ subdir is canonical; standards CLAUDE.md to be reconciled to it."
leases = "central, Kin.Gate-backed (NOT per-repo files) — fixes the bootstrap race; this IS the kin enhancement."
codecite-prooftrace = "their own CITE + PROVE contractile pair."
operating-mode = "full GitHub ops (token re-authed 2026-06-05)."
ledger = "this file."

[build-order]
# Owner-chosen sequence:
step-1 = "CVE/bump gate (unblocks the held dependabot backlog) — IN PROGRESS"
step-2 = "Attestation schema (Ed25519, reuse panic-attack intent->evidence->seal)"
step-3 = "Pool<->TRUST + Kin-backed lease/coordination spec (lands in standards)"
later  = "verisimdb entity model + PolicyDrift; CodeCite/ProofTrace"

